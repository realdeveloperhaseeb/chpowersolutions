# Copy to .env and fill in. If DB_HOST/DB_NAME are left blank, the app runs on an
# in-memory store (great for local preview; data resets on restart).

# ---- MySQL (local or Hostinger) ----
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---- Auth ----
# Long random string used to sign login sessions (JWT). REQUIRED in production.
JWT_SECRET=change-me-to-a-long-random-string

# ---- Email (order & contact notifications via Hostinger SMTP) ----
# Leave blank in dev — emails are skipped (logged to console) until configured.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="CH Power Solutions <no-reply@chpowersolutions.com>"
# NOTE: the recipient inbox for notifications is set in Admin → Settings
# (notify_email), not here. Default: arslanarain1514@gmail.com

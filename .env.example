# Copy to .env and fill in. If DB_HOST/DB_NAME are left blank, the app runs on an
# in-memory store (great for local preview; data resets on restart).

# ---- MySQL (local or Hostinger) ----
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---- Auth ----
# Long random string used to sign login sessions (JWT). REQUIRED in production.
JWT_SECRET=change-me-to-a-long-random-string

# ---- Email ----
# EASIEST (no SMTP): paste a free Web3Forms access key in Admin → Settings instead.
# Order/enquiry notifications are then delivered from the browser, no mail server.
#
# SMTP is OPTIONAL and only needed to also email customers (order confirmation /
# status). Leave blank to skip. The notify inbox is set in Admin → Settings
# (notify_email, default arslanarain1514@gmail.com), not here.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="CH Power Solutions <no-reply@chpowersolutions.com>"
